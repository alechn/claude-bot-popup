#!/bin/bash
# Stop hook wrapper: shows elapsed time of Claude's just-completed turn.
set -u

input=$(cat)
transcript=$(printf '%s' "$input" | jq -r '.transcript_path // ""' 2>/dev/null)

msg="done"
if [ -n "$transcript" ] && [ -f "$transcript" ]; then
  # Timestamp of the most recent user PROMPT (excludes tool_result events
  # which are also typed as "user" but represent tool output, not a prompt).
  start_ts=$(tail -500 "$transcript" 2>/dev/null | jq -rs '
    [ .[]
      | select(.type == "user")
      | select(
          (.message.content | type) == "string"
          or
          (.message.content | type == "array"
           and (all(.[]?; (.type // "") != "tool_result")))
        )
      | .timestamp
      | select(. != null)
    ] | last // ""
  ' 2>/dev/null)

  if [ -n "$start_ts" ]; then
    ts_no_ms="${start_ts%.*}Z"
    start_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts_no_ms" "+%s" 2>/dev/null || true)
    now_epoch=$(date "+%s")
    if [ -n "${start_epoch:-}" ]; then
      elapsed=$((now_epoch - start_epoch))
      if [ "$elapsed" -lt 0 ]; then
        msg="done"
      elif [ "$elapsed" -lt 60 ]; then
        msg="done, cooked for ${elapsed}s"
      else
        m=$((elapsed / 60))
        s=$((elapsed % 60))
        msg="done, cooked for ${m}m ${s}s"
      fi
    fi
  fi
fi

nohup "$HOME/.claude/bin/claude-notify" --message "$msg" --duration 4 --sound Pop </dev/null >/dev/null 2>&1 &
disown
exit 0
